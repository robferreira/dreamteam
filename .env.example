# Database
DATABASE_URL=postgresql+asyncpg://dreamteam:dreamteam@localhost:5432/dreamteam
DATABASE_URL_SYNC=postgresql+psycopg://dreamteam:dreamteam@localhost:5432/dreamteam

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8001/v1

# Embeddings / RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# Projects
PROJECTS_DIR=./projects

# Agent bundle (default, custom, skills, instructions, plugins)
AGENTS_BUNDLE_DIR=./agents

# App
APP_ENV=development
ALLOW_UNKNOWN_MODELS=true
REQUEST_TIMEOUT_SECONDS=120
MAX_ITERATIONS=20
MAX_AGENT_REVISITS=3

# Display timezone for API timestamps (IANA, e.g. America/Sao_Paulo)
DISPLAY_TIMEZONE=America/Sao_Paulo

# QA E2E
QA_RUN_TESTS=true
QA_AUTO_START_SERVERS=true
QA_API_TIMEOUT_SECONDS=120
QA_PLAYWRIGHT_TIMEOUT_SECONDS=300

# Auto-provision (npm/pip após frontend/backend)
AUTO_PROVISION=true
PROVISION_SKIP_IF_INSTALLED=true
PROVISION_NPM_TIMEOUT_SECONDS=300
PROVISION_PIP_TIMEOUT_SECONDS=180

# Recovery orchestrator
MAX_RECOVERY_ATTEMPTS=3
